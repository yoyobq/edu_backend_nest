{
  "name": "aigc-friendly-architecture-backend",
  "version": "1.0.0",
  "description": "A NestJS backend architecture optimized for AIGC/Copilot scenarios.",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run build:api",
    "build:api": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run start:api",
    "start:api": "NODE_ENV=production nest start",
    "start:dev": "npm run dev:api",
    "dev": "npm run dev:api",
    "dev:api": "NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/bootstraps/api/main",
    "lint:usecase-normalize-guard": "node scripts/check-usecase-normalize-guard.js",
    "lint": "npm run lint:usecase-normalize-guard && eslint \"{src,apps,libs,test}/**/*.ts\" --cache --cache-location .eslintcache --fix",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test": "clear && NODE_ENV=e2e node ./test/run-e2e-group.js core",
    "test:e2e": "clear && NODE_ENV=e2e node ./test/run-e2e-group.js core",
    "test:e2e:core": "clear && NODE_ENV=e2e node ./test/run-e2e-group.js core",
    "test:e2e:worker": "clear && NODE_ENV=e2e node ./test/run-e2e-group.js worker",
    "test:e2e:smoke": "clear && NODE_ENV=e2e node ./test/run-e2e-group.js smoke",
    "test:e2e:all": "npm run test:e2e:core && npm run test:e2e:worker",
    "test:e2e:file": "clear && NODE_ENV=e2e node ./test/run-e2e-group.js --file",
    "test:e2e:watch": "NODE_ENV=e2e node ./test/run-e2e-group.js --file --watch",
    "test:e2e:debug": "NODE_ENV=e2e node ./test/run-e2e-group.js --file --inspect-brk",
    "migration:drill:empty-db": "NODE_ENV=e2e ts-node -r tsconfig-paths/register src/infrastructure/database/verify-empty-db-migrations.ts",
    "ci:baseline-drill": "npm run migration:drill:empty-db",
    "dev:worker": "NODE_ENV=development ts-node -r tsconfig-paths/register src/bootstraps/worker/main.ts",
    "start:worker": "NODE_ENV=production node dist/bootstraps/worker/main"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.13.6",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "graphql": "^16.13.1",
    "graphql-type-json": "^0.3.2",
    "graphql-ws": "^6.0.7",
    "ioredis": "^5.10.1",
    "mysql2": "^3.20.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "packageManager": "npm@11.12.0"
}
