# 这是一个配置模板，请复制为 .env.development 或 .env.production 后填入实际值
NODE_ENV=
APP_NAME=
APP_PORT=
APP_HOST=
DEBUG=

# 日志配置
# LOG_LEVEL: debug | info | warn | error
# LOG_INCLUDE_REQUEST_META: 仅对 4xx 附带请求元信息（true/false）
LOG_LEVEL=
LOG_INCLUDE_REQUEST_META=

# CORS 配置（用于 src/core/config/server.config.ts）
# 是否启用 CORS（开发默认启用）
APP_CORS_ENABLED=true
# 允许的来源（逗号分隔）；生产环境启用 CORS 时必须显式配置
APP_CORS_ORIGINS=
# 是否允许携带凭据（Cookie / Authorization）
APP_CORS_CREDENTIALS=true

# GraphQL 开关
GRAPHQL_SANDBOX_ENABLED=false
GRAPHQL_INTROSPECTION_ENABLED=false

# 数据库基本连接配置
# 建议用 SSH 隧道连接数据库，避免直接暴露数据库端口
# 也可简化 API 和 WORKER 分别连接数据库时可以共享同一套配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=
DB_TIMEZONE=+08:00
DB_POOL_SIZE=10

# TypeORM 配置
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis 配置（BullMQ / Worker 共用）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=15
REDIS_PASSWORD=
REDIS_TLS=false
BULLMQ_PREFIX=bullmq

# 字段加密配置（用于 src/infrastructure/field-encryption/field-encryption.service.ts）
# 必填，建议使用 16 字符随机值
FIELD_ENCRYPTION_KEY=
FIELD_ENCRYPTION_IV=

# JWT 配置
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
JWT_ENABLE_REFRESH=true
JWT_ISSUER=ssts-local
JWT_AUDIENCE=DESKTOP,SSTSTEST,SSTSWEB,SSTSWEAPP,SJWEB,SJWEAPP
PAGINATION_HMAC_SECRET=

# 发信用户设置
EMAIL_SEND_AS_USER=no-reply-ssts

# QM Worker 入口开关
# 所有环境均可配置；开启后需通过入口守卫规则
AI_QUEUE_DEBUG_ENABLED=false
EMAIL_QUEUE_DEBUG_ENABLED=false

# AI Provider 配置
# 路由原则：
# 1) AI_PROVIDER_MODE=mock 时，强制走本地 mock，不发起远程请求
# 2) AI_PROVIDER_MODE=remote 时，仅当请求显式传 provider 才尝试走真实 provider
# 3) AI_PROVIDER_MODE=remote 且未传 provider 时，仍走本地 mock
AI_PROVIDER_MODE=mock

# Qwen 远程配置（可选，仅在 AI_PROVIDER_MODE=remote 且路由到 qwen 时生效）
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_GENERATE_MODEL=
QWEN_GENERATE_TIMEOUT_MS=30000

# OpenAI 远程配置（可选，仅在 AI_PROVIDER_MODE=remote 且路由显式传 provider=openai 时生效）
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_GENERATE_TIMEOUT_MS=30000

# 微信小程序
WECHAT_APP_ID=
WECHAT_APP_SECRET=
